# PASTEC Chrome Extension Environment Variables
# Use `.env-dev` for unpacked/development builds and `.env-prod` for production builds.
# The files below are examples only.

# Backend API URL
API_URL=https://pastec.ihu-liryc.fr

# Optional Keycloak overrides
# By default the extension derives KEYCLOAK_BASE_URL from the API URL origin + /auth
KEYCLOAK_BASE_URL=https://pastec.ihu-liryc.fr/auth
KEYCLOAK_REALM=pastec
KEYCLOAK_CLIENT_ID=pastec_plugin_prod
